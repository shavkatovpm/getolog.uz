---
interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Getolog - Telegram kanalingizni pullik qiling. Bot tokeningizni yuboring, biz avtomatlashtirilgan sotuvchi bot yaratamiz.",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://getolog.uz');
---

<!doctype html>
<html lang="uz">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalURL.href} />
    <link rel="alternate" hreflang="uz" href={canonicalURL.href} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:image" content="https://getolog.uz/logo.png" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://getolog.uz/logo.png" />

    <link rel="icon" id="favicon" type="image/png" href="/logo.png" />
    <link rel="apple-touch-icon" href="/logo.png" />

    <!-- Fonts: faqat ishlatilgan Inter & Outfit -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@600;700;800&display=swap" rel="stylesheet" />

    <!-- Schema.org structured data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "Getolog",
      "url": "https://getolog.uz",
      "description": description,
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "offers": [
        {
          "@type": "Offer",
          "name": "Bepul",
          "price": "0",
          "priceCurrency": "UZS"
        },
        {
          "@type": "Offer",
          "name": "Standard",
          "price": "97000",
          "priceCurrency": "UZS",
          "unitText": "oy"
        },
        {
          "@type": "Offer",
          "name": "Premium",
          "price": "197000",
          "priceCurrency": "UZS",
          "unitText": "oy"
        }
      ]
    })} />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Asosiy kontentga o'tish</a>
    <slot />
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>

<script>
  // Scroll reveal with IntersectionObserver (scroll listener o'rniga)
  const revealElements = document.querySelectorAll('.reveal');

  const revealObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('active');
          revealObserver.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1, rootMargin: '0px 0px -80px 0px' }
  );

  revealElements.forEach((el) => revealObserver.observe(el));

  // Rounded favicon from logo.png
  const faviconImg = new Image();
  faviconImg.crossOrigin = 'anonymous';
  faviconImg.onload = () => {
    const size = 64;
    const r = 20;
    const canvas = document.createElement('canvas');
    canvas.width = size;
    canvas.height = size;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;
    ctx.beginPath();
    ctx.moveTo(r, 0);
    ctx.lineTo(size - r, 0);
    ctx.quadraticCurveTo(size, 0, size, r);
    ctx.lineTo(size, size - r);
    ctx.quadraticCurveTo(size, size, size - r, size);
    ctx.lineTo(r, size);
    ctx.quadraticCurveTo(0, size, 0, size - r);
    ctx.lineTo(0, r);
    ctx.quadraticCurveTo(0, 0, r, 0);
    ctx.closePath();
    ctx.clip();
    ctx.drawImage(faviconImg, 0, 0, size, size);
    const link = document.getElementById('favicon') as HTMLLinkElement;
    if (link) link.href = canvas.toDataURL('image/png');
  };
  faviconImg.src = '/logo.png';
</script>
