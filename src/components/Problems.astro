---
import { type Lang, problems } from "../i18n/translations";

interface Props { lang?: Lang }
const lang = Astro.props.lang || "uz" as Lang;

const icons = [
  '<svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="var(--white)" stroke-width="1.5" aria-hidden="true"><path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/></svg>',
  '<svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="var(--white)" stroke-width="1.5" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>',
  '<svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="var(--white)" stroke-width="1.5" aria-hidden="true"><path d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>',
  '<svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="var(--white)" stroke-width="1.5" aria-hidden="true"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>',
];
---

<section class="section" id="features">
  <div class="container">
    <div class="section__header">
      <h2 class="section__title">{problems.title[lang]}</h2>
      <p class="section__subtitle">{problems.subtitle[lang]}</p>
    </div>

    <div class="problems-grid">
      {problems.cards.map((card, i) => (
        <div class="problem-card reveal">
          <div class="problem-card__icon" set:html={icons[i]} />
          <h3 class="problem-card__pain">{card.pain[lang]}</h3>
          <p class="problem-card__desc">{card.desc[lang]}</p>
          <div class="problem-card__solution">
            <div class="solution-tag">{problems.solutionTag[lang]}</div>
            <p set:html={card.solution[lang]} />
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .problems-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }

  .problem-card {
    background: var(--dark-800);
    border: 1px solid rgba(230, 233, 255, 0.06);
    border-radius: var(--radius-lg);
    padding: 36px 32px;
    transition: all var(--transition);
    display: flex;
    flex-direction: column;
    gap: 12px;
    position: relative;
    overflow: hidden;
  }

  .problem-card:hover {
    border-color: rgba(139, 142, 255, 0.2);
    transform: translateY(-4px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.2);
  }

  .problem-card__icon {
    position: absolute;
    top: -8px;
    right: -8px;
    width: 80px;
    height: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.07;
    pointer-events: none;
  }

  .problem-card:hover .problem-card__icon {
    opacity: 0.12;
  }

  .problem-card__pain {
    font-size: 1.1rem;
    font-weight: 700;
    line-height: 1.4;
    position: relative;
  }

  .problem-card__desc {
    font-size: 0.93rem;
    color: var(--light-400);
    line-height: 1.65;
    position: relative;
  }

  .problem-card__solution {
    padding-top: 14px;
    margin-top: 4px;
    border-top: 1px solid rgba(230, 233, 255, 0.06);
    position: relative;
  }

  .solution-tag {
    display: inline-block;
    padding: 4px 14px;
    background: rgba(74, 222, 128, 0.1);
    color: var(--success);
    border-radius: 100px;
    font-size: 0.8rem;
    font-weight: 600;
    margin-bottom: 10px;
    border: 1px solid rgba(74, 222, 128, 0.15);
  }

  .problem-card__solution p {
    font-size: 0.93rem;
    color: var(--light-200);
    line-height: 1.65;
  }

  @media (max-width: 768px) {
    .problems-grid {
      grid-template-columns: 1fr;
      gap: 16px;
    }

    .problem-card {
      padding: 28px 24px;
      gap: 10px;
    }

    .problem-card:hover {
      transform: none;
    }

    .problem-card__icon {
      width: 60px;
      height: 60px;
    }

    .problem-card__pain {
      font-size: 1rem;
    }

    .problem-card__desc {
      font-size: 0.88rem;
    }

    .problem-card__solution p {
      font-size: 0.88rem;
    }
  }
</style>
