---
import { type Lang, problems } from "../i18n/translations";

interface Props { lang?: Lang }
const lang = Astro.props.lang || "uz" as Lang;

const icons: Record<string, string> = {
  card: '<rect x="2" y="5" width="20" height="14" rx="2"/><path d="M2 10h20"/>',
  receipt: '<path d="M6 2h12v18l-3-2-3 2-3-2-3 2V2z"/><path d="M9 7h6M9 11h6"/>',
  link: '<path d="M9 12a4 4 0 015.66-3.66l2.5-2.5a4 4 0 015.66 5.66l-2.5 2.5"/><path d="M15 12a4 4 0 01-5.66 3.66l-2.5 2.5a4 4 0 01-5.66-5.66l2.5-2.5"/>',
  clock: '<circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/>',
  bell: '<path d="M12 4a5 5 0 015 5v3l2 4H5l2-4V9a5 5 0 015-5z"/><path d="M10 20a2 2 0 004 0"/>',
  sliders: '<path d="M4 6h10M4 12h16M4 18h7"/><circle cx="17" cy="6" r="2"/><circle cx="8" cy="18" r="2"/>',
  users: '<circle cx="9" cy="8" r="3.5"/><path d="M2 20c0-3.3 3.1-6 7-6s7 2.7 7 6"/><path d="M17 8.5a3 3 0 010 6"/><path d="M17.5 14.5c2.5.3 4.5 2.5 4.5 5.5"/>',
  refresh: '<path d="M20 11A8 8 0 105.5 16.5"/><path d="M20 5v6h-6"/>',
  calendar: '<rect x="3" y="5" width="18" height="16" rx="2"/><path d="M3 10h18M8 3v4M16 3v4"/>',
  layers: '<path d="M12 3l9 5-9 5-9-5 9-5z"/><path d="M3 13l9 5 9-5"/>',
  chart: '<path d="M4 20V10M12 20V4M20 20v-7"/>',
  id: '<rect x="3" y="5" width="18" height="14" rx="2"/><circle cx="8.5" cy="11" r="2"/><path d="M6 16c.5-1.8 1.8-3 2.5-3s2 1.2 2.5 3"/><path d="M14 9h4M14 13h4"/>',
};
---

<section class="section" id="features">
  <div class="container">
    <div class="section__header">
      <h2 class="section__title">{problems.title[lang]}</h2>
      <p class="section__subtitle" set:html={problems.subtitle[lang]} />
    </div>

    <div class="feature-groups">
      {problems.groups.map((g) => (
        <div class="feature-group reveal">
          <h3 class="feature-group__name">{g.name[lang]}</h3>
          <div class="feature-group__items">
            {g.items.map((item) => (
              <div class="feature-group__item">
                <svg class="feature-group__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true" set:html={icons[item.icon]} />
                <div>
                  <div class="feature-group__item-title">{item.title[lang]}</div>
                  <div class="feature-group__item-text">{item.text[lang]}</div>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .feature-groups {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  .feature-group {
    background: #FFFFFF;
    border: 1px solid var(--dark-700);
    border-radius: var(--radius-lg);
    padding: 32px;
  }

  .feature-group__name {
    font-family: 'Kalam', cursive;
    font-weight: 700;
    font-size: 1.3rem;
    color: var(--accent);
    margin-bottom: 22px;
  }

  .feature-group__items {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .feature-group__item {
    display: flex;
    gap: 14px;
    align-items: flex-start;
  }

  .feature-group__icon {
    width: 22px;
    height: 22px;
    color: var(--accent);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .feature-group__item-title {
    font-weight: 700;
    font-size: 0.95rem;
    margin-bottom: 3px;
  }

  .feature-group__item-text {
    font-size: 0.85rem;
    color: var(--light-400);
    line-height: 1.55;
  }

  :global(.problems-subtitle-break) {
    display: none;
  }

  @media (max-width: 768px) {
    .feature-groups {
      grid-template-columns: 1fr;
      gap: 16px;
    }

    .feature-group {
      padding: 26px 22px;
    }

    :global(.problems-subtitle-break) {
      display: block;
    }
  }
</style>
