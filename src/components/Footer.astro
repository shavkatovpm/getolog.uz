---
import { type Lang, footer as ft, langPrefix } from "../i18n/translations";

interface Props { lang?: Lang }
const lang = Astro.props.lang || "uz" as Lang;
const prefix = langPrefix(lang);
---

<footer class="footer" role="contentinfo">
  <div class="container footer__inner">
    <div class="footer__top">
      <div class="footer__brand">
        <a href={prefix + "/"} class="footer__logo" aria-label="Getolog">
          <img src="/logo.png" alt="Getolog" class="logo-img" />
          <span>Getolog</span>
        </a>
        <p class="footer__tagline">{ft.tagline[lang]}</p>
      </div>
      <nav class="footer__links" aria-label={lang === "uz" ? "Footer navigatsiya" : "Навигация"}>
        <a href="https://t.me/getolog_bot" target="_blank" rel="noopener noreferrer">{ft.bot[lang]}</a>
        <a href="https://t.me/getologbot" target="_blank" rel="noopener noreferrer">{ft.help[lang]}</a>
        <a href={prefix + "/#faq"}>FAQ</a>
        <a href={prefix + "/info"}>{ft.info[lang]}</a>
        <a href={prefix + "/offerta"}>{ft.offerta[lang]}</a>
      </nav>
    </div>
    <div class="footer__bottom">
      <p>{ft.copyright[lang]}</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid rgba(230, 233, 255, 0.06);
    padding: 48px 0 32px;
  }

  .footer__top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 40px;
  }

  .footer__logo {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 1.2rem;
    font-weight: 700;
    margin-bottom: 8px;
  }

  .logo-img {
    width: 32px;
    height: 32px;
    border-radius: 8px;
    object-fit: cover;
  }

  .footer__tagline {
    font-size: 0.9rem;
    color: var(--dark-600);
  }

  .footer__links {
    display: flex;
    gap: 28px;
  }

  .footer__links a {
    font-size: 0.95rem;
    color: var(--light-400);
    transition: color var(--transition);
  }

  .footer__links a:hover {
    color: var(--light);
  }

  .footer__bottom {
    padding-top: 24px;
    border-top: 1px solid rgba(230, 233, 255, 0.06);
  }

  .footer__bottom p {
    font-size: 0.85rem;
    color: var(--dark-600);
  }

  @media (max-width: 768px) {
    .footer {
      padding: 36px 0 28px;
    }

    .footer__top {
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 20px;
      margin-bottom: 28px;
    }

    .footer__brand {
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .footer__links {
      gap: 24px;
    }

    .footer__links a {
      font-size: 0.9rem;
    }

    .footer__bottom {
      text-align: center;
      padding-top: 20px;
    }

    .footer__bottom p {
      font-size: 0.8rem;
    }
  }
</style>
