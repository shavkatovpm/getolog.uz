---
import { type Lang, hero, langPrefix } from "../i18n/translations";

interface Props { lang?: Lang }
const lang = Astro.props.lang || "uz" as Lang;
const prefix = langPrefix(lang);
---

<section class="hero" id="main-content">
  <div class="hero__floating-lights" aria-hidden="true">
    <div class="light light--2"></div>
    <div class="light light--3"></div>
    <div class="light light--4"></div>
    <div class="light light--5"></div>
    <div class="light light--6"></div>
  </div>
  <div class="container hero__inner">
    <div class="hero__content">
      <h1 class="hero__title fade-in-up delay-1" set:html={hero.title[lang]} />
      <p class="hero__subtitle fade-in-up delay-2" set:html={hero.subtitle[lang]} />
      <div class="hero__actions fade-in-up delay-3">
        <a href="https://t.me/getolog_bot" target="_blank" rel="noopener noreferrer" class="btn btn--primary btn--lg">
          {hero.startBtn[lang]}
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href={prefix + "/ariza"} class="btn btn--ghost btn--lg">{hero.consultBtn[lang]}</a>
      </div>
      <div class="hero__stats fade-in-up delay-4">
        <div class="stat">
          <span class="stat__number">{hero.stat1num[lang]}</span>
          <span class="stat__label">{hero.stat1label[lang]}</span>
        </div>
        <div class="stat__divider" aria-hidden="true"></div>
        <div class="stat">
          <span class="stat__number">{hero.stat2num[lang]}</span>
          <span class="stat__label">{hero.stat2label[lang]}</span>
        </div>
        <div class="stat__divider" aria-hidden="true"></div>
        <div class="stat">
          <span class="stat__number">{hero.stat3num[lang]}</span>
          <span class="stat__label">{hero.stat3label[lang]}</span>
        </div>
      </div>
    </div>
    <div class="hero__visual fade-in delay-3" aria-hidden="true">
      <div class="phone-mockup">
        <div class="phone-mockup__notch"></div>
        <div class="phone-mockup__screen">
          <div class="chat-header">
            <div class="chat-header__avatar">P</div>
            <div>
              <div class="chat-header__name">{hero.phoneName[lang]}</div>
              <div class="chat-header__status">{hero.phoneStatus[lang]}</div>
            </div>
          </div>
          <div class="chat-demo">
            <div class="chat-msg chat-msg--bot">
              <div class="chat-msg__bubble">{hero.phoneGreeting[lang]}</div>
            </div>
            <div class="chat-msg chat-msg--bot">
              <div class="chat-buttons">
                <span class="chat-btn">{hero.phoneBtn1[lang]}</span>
                <span class="chat-btn">{hero.phoneBtn2[lang]}</span>
                <span class="chat-btn">{hero.phoneBtn3[lang]}</span>
              </div>
            </div>
            <div class="chat-msg chat-msg--user">
              <div class="chat-msg__bubble">{hero.phoneUserMsg[lang]}</div>
            </div>
            <div class="chat-msg chat-msg--bot">
              <div class="chat-msg__bubble" set:html={hero.phoneCardInfo[lang]} />
            </div>
            <div class="chat-msg chat-msg--bot success-msg">
              <div class="chat-msg__bubble" set:html={hero.phoneSuccess[lang]} />
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    --h-bg: #F0F1F3;
    --h-ink: #1A1D22;
    --h-muted: #666E7A;
    --h-border: #DCDFE4;
    --h-accent: #5B6B7A;
    --h-accent-dark: #47535F;
    --h-accent-ink: #FFFFFF;
    --h-card: #FFFFFF;
    --h-card-inner: #F3F4F6;
    --h-success: #4F7D6E;
    background-color: var(--h-bg);
    color: var(--h-ink);
    padding: 70px 0 60px;
    position: relative;
    overflow: clip;
    min-height: 100vh;
    display: flex;
    align-items: center;
    font-family: 'Inter Tight', sans-serif;
  }

  .hero .btn--primary {
    background: var(--h-accent);
    color: var(--h-accent-ink);
  }

  .hero .btn--primary:hover {
    background: var(--h-accent-dark);
  }

  .hero .btn--ghost {
    border-color: var(--h-border);
    color: var(--h-ink);
  }

  .hero .btn--ghost:hover {
    border-color: var(--h-accent);
    background: rgba(91, 107, 122, 0.06);
  }

  .hero__floating-lights {
    position: absolute;
    width: 100%;
    height: 100%;
    overflow: hidden;
    pointer-events: none;
  }

  .light {
    position: absolute;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(91, 107, 122, 0.18) 0%, rgba(91, 107, 122, 0.06) 40%, transparent 70%);
    filter: blur(15px);
    will-change: transform, opacity;
    animation: float-around 20s ease-in-out infinite;
  }

  .light--2 {
    width: 100px;
    height: 100px;
    top: 40%;
    right: 60%;
    animation-delay: 3s;
    animation-duration: 20s;
  }

  .light--3 {
    width: 120px;
    height: 120px;
    top: 70%;
    right: 20%;
    animation-delay: 6s;
    animation-duration: 22s;
  }

  .light--4 {
    width: 80px;
    height: 80px;
    top: 25%;
    right: 80%;
    animation-delay: 9s;
    animation-duration: 18s;
  }

  .light--5 {
    width: 110px;
    height: 110px;
    top: 55%;
    right: 40%;
    animation-delay: 12s;
    animation-duration: 24s;
  }

  .light--6 {
    width: 90px;
    height: 90px;
    top: 85%;
    right: 70%;
    animation-delay: 15s;
    animation-duration: 21s;
  }

  @keyframes float-around {
    0%, 100% {
      transform: translate(0, 0) scale(1);
      opacity: 0.2;
    }
    25% {
      transform: translate(-100px, 80px) scale(1.2);
      opacity: 0.35;
    }
    50% {
      transform: translate(120px, -60px) scale(0.9);
      opacity: 0.2;
    }
    75% {
      transform: translate(-80px, 100px) scale(1.1);
      opacity: 0.3;
    }
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 80px;
    align-items: center;
  }

  .hero__badge {
    display: inline-block;
    padding: 8px 18px;
    background: rgba(91, 107, 122, 0.1);
    color: var(--h-accent);
    border-radius: 100px;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 24px;
    border: 1px solid rgba(91, 107, 122, 0.2);
    opacity: 0;
  }

  .hero__title {
    font-family: 'Inter Tight', sans-serif;
    font-size: clamp(2.5rem, 5.5vw, 3.75rem);
    font-weight: 800;
    line-height: 1.15;
    margin-bottom: 24px;
    letter-spacing: -1px;
    opacity: 0;
  }

  .hero__subtitle {
    font-size: 1.2rem;
    color: var(--h-muted);
    line-height: 1.75;
    margin-bottom: 40px;
    max-width: 540px;
    opacity: 0;
  }

  .hero__actions {
    display: flex;
    gap: 16px;
    margin-bottom: 56px;
    opacity: 0;
  }

  .hero__actions .btn {
    flex: 1 1 0;
    min-width: 0;
  }

  .hero__stats {
    display: flex;
    gap: 36px;
    align-items: center;
    opacity: 0;
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .stat__number {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--h-ink);
    letter-spacing: -0.5px;
  }

  .stat__label {
    font-size: 0.85rem;
    color: var(--h-muted);
    font-weight: 500;
  }

  .stat__divider {
    width: 1px;
    height: 44px;
    background: linear-gradient(to bottom, transparent, var(--h-border), transparent);
  }

  /* Phone Mockup */
  .hero__visual {
    opacity: 0;
    position: relative;
    padding: 50px 40px 60px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .phone-mockup {
    width: 100%;
    max-width: 360px;
    margin: 0 auto;
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-radius: 48px;
    padding: 16px;
    border: 1px solid rgba(91, 107, 122, 0.15);
    box-shadow:
      0 30px 60px rgba(20, 25, 35, 0.12),
      0 0 0 1px rgba(91, 107, 122, 0.06) inset,
      0 15px 40px rgba(91, 107, 122, 0.08);
    position: relative;
    animation: float 6s ease-in-out infinite;
    animation-delay: 0.5s;
    animation-play-state: paused;
    transform: perspective(1000px) rotateY(-2deg) rotateX(1deg);
    transform-style: preserve-3d;
  }

  .phone-mockup::before {
    content: '';
    position: absolute;
    top: 10%;
    left: -10%;
    width: 50%;
    height: 80%;
    background: linear-gradient(135deg, rgba(91, 107, 122, 0.14) 0%, transparent 60%);
    border-radius: 50%;
    filter: blur(30px);
    z-index: -1;
    animation: pulse 4s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% {
      opacity: 0.5;
      transform: scale(1);
    }
    50% {
      opacity: 0.8;
      transform: scale(1.1);
    }
  }

  .phone-mockup__notch {
    width: 120px;
    height: 28px;
    background: transparent;
    border-radius: 0 0 20px 20px;
    margin: 0 auto 0;
    position: relative;
    z-index: 2;
  }

  .phone-mockup__screen {
    background:
      linear-gradient(135deg, rgba(91, 107, 122, 0.05) 0%, transparent 50%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(243, 244, 246, 0.98) 100%);
    border-radius: 32px;
    overflow: hidden;
    margin-top: -14px;
    box-shadow: 0 0 40px rgba(20, 25, 35, 0.04) inset;
    position: relative;
  }

  .phone-mockup__screen::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background:
      radial-gradient(circle at 20% 30%, rgba(91, 107, 122, 0.05) 0%, transparent 40%),
      radial-gradient(circle at 80% 70%, rgba(91, 107, 122, 0.04) 0%, transparent 40%);
    pointer-events: none;
  }

  .chat-header {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 24px 18px 14px;
    background: linear-gradient(180deg, rgba(220, 223, 228, 0.5) 0%, transparent 100%);
    border-bottom: 1px solid rgba(91, 107, 122, 0.1);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .chat-header__avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--h-accent) 0%, var(--h-accent-dark) 100%);
    color: var(--h-accent-ink);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 0.97rem;
    box-shadow: 0 4px 16px rgba(91, 107, 122, 0.35);
    border: 2px solid rgba(255, 255, 255, 0.4);
  }

  .chat-header__name {
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--h-ink);
  }

  .chat-header__status {
    font-size: 0.72rem;
    color: var(--h-success);
    font-weight: 500;
  }

  .chat-demo {
    padding: 18px 16px 20px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-height: 460px;
    overflow: hidden;
  }

  .chat-msg {
    display: flex;
    animation: slideInLeft 0.4s ease-out;
  }

  .chat-msg--user {
    justify-content: flex-end;
    animation: slideInRight 0.4s ease-out;
  }

  .chat-msg__bubble {
    max-width: 85%;
    padding: 11px 15px;
    border-radius: 16px;
    font-size: 0.78rem;
    line-height: 1.55;
  }

  .chat-msg--bot .chat-msg__bubble {
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-bottom-left-radius: 6px;
    border: 1px solid rgba(91, 107, 122, 0.12);
    box-shadow: 0 2px 8px rgba(20, 25, 35, 0.05);
  }

  .chat-msg--user .chat-msg__bubble {
    background: linear-gradient(135deg, var(--h-accent) 0%, var(--h-accent-dark) 100%);
    color: var(--h-accent-ink);
    border-bottom-right-radius: 6px;
    box-shadow: 0 4px 16px rgba(91, 107, 122, 0.3);
    border: 1px solid rgba(255, 255, 255, 0.15);
  }

  .success-msg .chat-msg__bubble {
    border: 1px solid rgba(79, 125, 110, 0.3);
    background: rgba(79, 125, 110, 0.1);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    box-shadow: 0 2px 12px rgba(79, 125, 110, 0.12);
  }

  .invite-link {
    color: var(--h-accent);
    font-weight: 600;
    text-decoration: none;
    border-bottom: 1.5px dashed rgba(91, 107, 122, 0.5);
    padding: 2px 4px;
    background: rgba(91, 107, 122, 0.08);
    border-radius: 4px;
    transition: all var(--transition);
  }

  .invite-link:hover {
    background: rgba(91, 107, 122, 0.15);
    border-bottom-color: var(--h-accent);
  }

  .chat-buttons {
    display: flex;
    flex-direction: column;
    gap: 9px;
  }

  .chat-btn {
    display: block;
    padding: 11px 17px;
    background: rgba(91, 107, 122, 0.08);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(91, 107, 122, 0.25);
    border-radius: 12px;
    font-size: 0.78rem;
    text-align: center;
    color: var(--h-accent);
    cursor: default;
    transition: all var(--transition);
    font-weight: 500;
  }

  .chat-btn:hover {
    background: rgba(91, 107, 122, 0.14);
    border-color: rgba(91, 107, 122, 0.35);
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(91, 107, 122, 0.18);
  }

  .hero__br {
    display: block;
  }

  @media (max-width: 1200px) {
    .hero__visual {
      padding: 40px 30px 50px;
    }

    .phone-mockup {
      transform: perspective(1000px) rotateY(-1deg) rotateX(0deg);
    }
  }

  @media (max-width: 968px) {
    .hero {
      padding: 70px 0 40px;
      min-height: auto;
    }

    .hero__inner {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 64px;
    }

    .hero__subtitle {
      margin: 0 auto 32px;
    }

    .hero__actions {
      justify-content: center;
      margin-bottom: 48px;
    }

    .hero__stats {
      justify-content: center;
    }

    .hero__visual {
      max-width: 400px;
      margin: 0 auto;
      padding: 30px 20px 40px;
    }

    .phone-mockup {
      transform: none;
    }
  }

  @media (max-width: 768px) {
    .hero {
      padding: 65px 0 35px;
    }

    .hero__title {
      font-size: clamp(2rem, 7.5vw, 2.6rem);
    }

    .hero__subtitle {
      font-size: clamp(1rem, 3.8vw, 1.15rem);
      line-height: 1.65;
    }

    .hero__actions {
      margin-bottom: 40px;
    }

    .hero__actions .btn--lg {
      padding: 16px 20px;
      font-size: 1rem;
    }

    .hero__stats {
      gap: 28px;
    }

    .stat__number {
      font-size: 1.3rem;
    }

    .stat__divider {
      height: 36px;
    }

    .hero__visual {
      padding: 25px 15px 35px;
    }

    .phone-mockup {
      max-width: 330px;
    }
  }

  @media (max-width: 480px) {
    .hero {
      padding: 120px 0 60px;
      min-height: 100vh;
      display: flex;
      align-items: center;
    }

    .hero__inner {
      gap: 48px;
    }

    .hero__br {
      display: inline;
    }

    .hero__badge {
      font-size: 0.8rem;
      padding: 6px 16px;
      margin-bottom: 20px;
    }

    .hero__title {
      font-size: clamp(1.85rem, calc(10vw - 3px), 2.6rem);
      margin-bottom: 24px;
      line-height: 1.22;
    }

    .hero__subtitle {
      font-size: clamp(0.98rem, 4.6vw, 1.1rem);
      line-height: 1.5;
      margin-bottom: 24px;
    }

    .hero__actions {
      margin-bottom: 32px;
      gap: 10px;
    }

    .hero__actions .btn--lg {
      padding: 14px 10px;
      font-size: 0.9rem;
    }

    .hero__stats {
      gap: 16px;
      flex-wrap: nowrap;
      justify-content: space-between;
      max-width: 100%;
    }

    .stat {
      flex: 1;
      min-width: 0;
    }

    .stat__number {
      font-size: 1.1rem;
    }

    .stat__label {
      font-size: 0.75rem;
    }

    .stat__divider {
      height: 28px;
    }

    .hero__visual {
      padding: 0 0 20px;
    }

    .phone-mockup {
      max-width: 280px;
      padding: 10px;
      border-radius: 32px;
      box-shadow:
        0 15px 35px rgba(20, 25, 35, 0.12),
        0 0 0 1px rgba(91, 107, 122, 0.08) inset,
        0 8px 20px rgba(91, 107, 122, 0.06);
    }

    .phone-mockup::before {
      display: none;
    }

    .phone-mockup__notch {
      width: 100px;
      height: 24px;
    }

    .phone-mockup__screen {
      border-radius: 24px;
    }

    .chat-header {
      padding: 18px 14px 10px;
    }

    .chat-header__avatar {
      width: 36px;
      height: 36px;
      font-size: 0.85rem;
    }

    .chat-header__name {
      font-size: 0.85rem;
    }

    .chat-header__status {
      font-size: 0.7rem;
    }

    .chat-demo {
      padding: 14px 10px 16px;
      gap: 9px;
      max-height: 420px;
    }

    .chat-msg__bubble {
      text-align: left;
      color: var(--h-ink);
      font-size: 0.72rem;
      padding: 10px 13px;
      border-radius: 14px;
    }

    .chat-msg--user .chat-msg__bubble {
      color: var(--h-accent-ink);
    }

    .chat-btn {
      padding: 10px 14px;
      font-size: 0.72rem;
      border-radius: 10px;
    }

    .invite-link {
      font-size: 0.72rem;
    }
  }
</style>

<script>
  // Pause phone animation when not visible for performance
  const phoneMockup = document.querySelector('.phone-mockup');
  if (phoneMockup) {
    const phoneObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          (entry.target as HTMLElement).style.animationPlayState = entry.isIntersecting ? 'running' : 'paused';
        });
      },
      { threshold: 0 }
    );
    phoneObserver.observe(phoneMockup);
  }
</script>
