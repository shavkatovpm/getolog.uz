---
import { type Lang, pricing, langPrefix } from "../i18n/translations";

interface Props { lang?: Lang }
const lang = Astro.props.lang || "uz" as Lang;
const prefix = langPrefix(lang);
---

<section class="section" id="pricing">
  <div class="container">
    <div class="section__header">
      <h2 class="section__title">{pricing.title[lang]}</h2>
      <p class="section__subtitle">{pricing.subtitle[lang]}</p>
    </div>

    <div class="pricing-grid">
      <!-- Bepul -->
      <div class="pricing-card reveal">
        <div class="pricing-card__header">
          <h3 class="pricing-card__name">{pricing.free[lang]}</h3>
          <div class="pricing-card__price">
            <span class="price-amount">0</span>
            <span class="price-currency">{pricing.currency[lang]}</span>
          </div>
        </div>
        <ul class="pricing-card__features" aria-label={pricing.free[lang]}>
          <li class="included">{pricing.freeSubs[lang]}</li>
          <li class="included">{pricing.featManualPay[lang]}</li>
          <li class="included">{pricing.featExpiry[lang]}</li>
          <li class="included">{pricing.featPlans[lang]}</li>
          <li class="excluded">{pricing.featPayme[lang]}</li>
          <li class="excluded">{pricing.featReferral[lang]}</li>
        </ul>
        <a href="https://t.me/getolog_bot" target="_blank" rel="noopener noreferrer" class="btn btn--outline btn--full">{pricing.startBtn[lang]}</a>
      </div>

      <!-- Start -->
      <div class="pricing-card reveal">
        <div class="pricing-card__header">
          <h3 class="pricing-card__name">{pricing.start[lang]}</h3>
          <div class="pricing-card__price">
            <span class="price-amount">597 000</span>
            <span class="price-currency">{pricing.currencyMonth[lang]}</span>
          </div>
        </div>
        <ul class="pricing-card__features" aria-label={pricing.start[lang]}>
          <li class="included">{pricing.startSubs[lang]}</li>
          <li class="included">{pricing.featManualPay[lang]}</li>
          <li class="included">{pricing.featExpiry[lang]}</li>
          <li class="included">{pricing.featPlans[lang]}</li>
          <li class="excluded">{pricing.featPayme[lang]}</li>
          <li class="excluded">{pricing.featReferral[lang]}</li>
        </ul>
        <a href="https://t.me/getolog_bot" target="_blank" rel="noopener noreferrer" class="btn btn--outline btn--full">{pricing.startBtn[lang]}</a>
      </div>

      <!-- Pro -->
      <div class="pricing-card pricing-card--popular reveal">
        <span class="popular-badge">{pricing.badge[lang]}</span>
        <div class="pricing-card__header">
          <h3 class="pricing-card__name">{pricing.pro[lang]}</h3>
          <div class="pricing-card__price">
            <span class="price-amount">1 270 000</span>
            <span class="price-currency">{pricing.currencyMonth[lang]}</span>
          </div>
        </div>
        <ul class="pricing-card__features" aria-label={pricing.pro[lang]}>
          <li class="included">{pricing.proSubs[lang]}</li>
          <li class="included">{pricing.featPayme[lang]}</li>
          <li class="included">{pricing.featReferral[lang]}</li>
          <li class="included">{pricing.featAutopost[lang]}</li>
          <li class="included">{pricing.featExpiry[lang]}</li>
          <li class="included">{pricing.featPlans[lang]}</li>
        </ul>
        <a href="https://t.me/getolog_bot" target="_blank" rel="noopener noreferrer" class="btn btn--primary btn--full">{pricing.startBtn[lang]}</a>
      </div>

      <!-- Biznes -->
      <div class="pricing-card reveal">
        <div class="pricing-card__header">
          <h3 class="pricing-card__name">{pricing.business[lang]}</h3>
          <div class="pricing-card__price">
            <span class="price-amount">1 890 000</span>
            <span class="price-currency">{pricing.currencyMonth[lang]}</span>
          </div>
        </div>
        <ul class="pricing-card__features" aria-label={pricing.business[lang]}>
          <li class="included">{pricing.businessSubs[lang]}</li>
          <li class="included">{pricing.featPayme[lang]}</li>
          <li class="included">{pricing.featReferral[lang]}</li>
          <li class="included">{pricing.featAutopost[lang]}</li>
          <li class="included">{pricing.featCRM[lang]}</li>
          <li class="included">{pricing.featPlans[lang]}</li>
        </ul>
        <a href="https://t.me/getolog_bot" target="_blank" rel="noopener noreferrer" class="btn btn--outline btn--full">{pricing.startBtn[lang]}</a>
      </div>
    </div>

    <p class="pricing-note">
      <a href={prefix + "/price"} class="pricing-note__link">{pricing.compareLink[lang]}</a>
    </p>
  </div>
</section>

<style>
  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    max-width: 1240px;
    margin: 0 auto;
  }

  .pricing-card {
    background: #FFFFFF;
    border: 1px solid rgba(26, 29, 34, 0.07);
    border-radius: var(--radius-lg);
    padding: 36px 28px;
    transition: all var(--transition);
    position: relative;
  }

  .pricing-card:hover {
    border-color: rgba(91, 107, 122, 0.25);
    transform: translateY(-4px);
    box-shadow: 0 20px 40px rgba(20, 25, 35, 0.08);
  }

  .pricing-card--popular {
    border-color: var(--accent);
    box-shadow: 0 0 30px rgba(91, 107, 122, 0.12);
  }

  .pricing-card--popular:hover {
    border-color: var(--accent);
  }

  .popular-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--accent);
    color: var(--dark);
    font-size: 0.75rem;
    font-weight: 700;
    padding: 4px 16px;
    border-radius: 100px;
    letter-spacing: 0.5px;
  }

  .pricing-card__header {
    text-align: center;
    margin-bottom: 28px;
    padding-bottom: 28px;
    border-bottom: 1px solid rgba(26, 29, 34, 0.08);
  }

  .pricing-card__name {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--light);
    margin-bottom: 12px;
  }

  .price-amount {
    font-size: 2.25rem;
    font-weight: 800;
    color: var(--white);
  }

  .price-currency {
    font-size: 0.9rem;
    color: var(--light-400);
    margin-left: 4px;
  }

  .pricing-card__features {
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin-bottom: 32px;
    list-style: none;
    padding: 0;
  }

  .pricing-card__features li {
    font-size: 0.9rem;
    color: var(--light);
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .pricing-card__features li::before {
    font-weight: 700;
    font-size: 1rem;
    flex-shrink: 0;
    width: 18px;
    text-align: center;
  }

  .pricing-card__features li.included::before {
    content: '\2713';
    color: var(--success);
  }

  .pricing-card__features li.excluded {
    color: var(--light-400);
  }

  .pricing-card__features li.excluded::before {
    content: '\00d7';
    color: var(--light-400);
  }

  .pricing-note {
    text-align: center;
    margin-top: 40px;
  }

  .pricing-note__link {
    font-size: 0.95rem;
    color: var(--accent);
    font-weight: 600;
    transition: all var(--transition);
  }

  .pricing-note__link:hover {
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  @media (max-width: 900px) {
    .pricing-grid {
      grid-template-columns: repeat(2, 1fr);
      max-width: 640px;
      gap: 20px;
    }
  }

  @media (max-width: 560px) {
    .pricing-grid {
      grid-template-columns: 1fr;
      max-width: 400px;
    }
  }

  @media (max-width: 768px) {
    .pricing-card {
      padding: 32px 24px;
    }

    .pricing-card:hover {
      transform: none;
    }

    .pricing-card__header {
      margin-bottom: 24px;
      padding-bottom: 24px;
    }

    .pricing-card__name {
      font-size: 1.1rem;
    }

    .price-amount {
      font-size: 2rem;
    }

    .pricing-card__features {
      gap: 12px;
      margin-bottom: 28px;
    }

    .pricing-card__features li {
      font-size: 0.85rem;
    }
  }
</style>
