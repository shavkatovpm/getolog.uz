---

---

<section class="section" id="pricing">
  <div class="container">
    <div class="section__header">
      <h2 class="section__title">Tariflar</h2>
      <p class="section__subtitle">Kanalingiz hajmiga mos tarifni tanlang</p>
    </div>

    <div class="pricing-grid">
      <!-- Bepul -->
      <div class="pricing-card reveal">
        <div class="pricing-card__header">
          <h3 class="pricing-card__name">Bepul</h3>
          <div class="pricing-card__price">
            <span class="price-amount">0</span>
            <span class="price-currency">so'm</span>
          </div>
        </div>
        <ul class="pricing-card__features" aria-label="Bepul tarif xususiyatlari">
          <li class="included">1 ta bot</li>
          <li class="included">Karta orqali to'lov</li>
          <li class="included">Statistika</li>
          <li class="included">Avtomatik boshqaruvi</li>
          <li class="excluded">Reklamani o'chirish</li>
          <li class="excluded">Multi-admin</li>
          <li class="excluded">Click / Payme</li>
        </ul>
        <a href="https://t.me/getolog_bot" target="_blank" rel="noopener noreferrer" class="btn btn--outline btn--full">Boshlash</a>
      </div>

      <!-- Standard -->
      <div class="pricing-card pricing-card--popular reveal">
        <span class="popular-badge">Tavsiya</span>
        <div class="pricing-card__header">
          <h3 class="pricing-card__name">Standard</h3>
          <div class="pricing-card__price">
            <span class="price-amount">97 000</span>
            <span class="price-currency">so'm/oy</span>
          </div>
        </div>
        <ul class="pricing-card__features" aria-label="Standard tarif xususiyatlari">
          <li class="included">2 ta bot</li>
          <li class="included">Karta orqali to'lov</li>
          <li class="included">Statistika</li>
          <li class="included">Avtomatik boshqaruvi</li>
          <li class="included">Reklamani o'chirish</li>
          <li class="included">2 ta multi-admin</li>
          <li class="excluded">Click / Payme</li>
        </ul>
        <a href="https://t.me/getolog_bot" target="_blank" rel="noopener noreferrer" class="btn btn--primary btn--full">Boshlash</a>
      </div>

      <!-- Premium -->
      <div class="pricing-card reveal">
        <div class="pricing-card__header">
          <h3 class="pricing-card__name">Premium</h3>
          <div class="pricing-card__price">
            <span class="price-amount">197 000</span>
            <span class="price-currency">so'm/oy</span>
          </div>
        </div>
        <ul class="pricing-card__features" aria-label="Premium tarif xususiyatlari">
          <li class="included">5 ta bot</li>
          <li class="included">Karta orqali to'lov</li>
          <li class="included">Statistika</li>
          <li class="included">Avtomatik boshqaruvi</li>
          <li class="included">Reklamani o'chirish</li>
          <li class="included">5 ta multi-admin</li>
          <li class="included">Click / Payme</li>
        </ul>
        <a href="https://t.me/getolog_bot" target="_blank" rel="noopener noreferrer" class="btn btn--outline btn--full">Boshlash</a>
      </div>
    </div>

    <p class="pricing-note">
      <a href="/price" class="pricing-note__link">Batafsil taqqoslash &rarr;</a>
    </p>
  </div>
</section>

<style>
  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    max-width: 1020px;
    margin: 0 auto;
  }

  .pricing-card {
    background: var(--dark-800);
    border: 1px solid rgba(230, 233, 255, 0.06);
    border-radius: var(--radius-lg);
    padding: 36px 28px;
    transition: all var(--transition);
    position: relative;
  }

  .pricing-card:hover {
    border-color: rgba(139, 142, 255, 0.2);
    transform: translateY(-4px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.2);
  }

  .pricing-card--popular {
    border-color: var(--accent);
    box-shadow: 0 0 30px rgba(139, 142, 255, 0.1);
  }

  .pricing-card--popular:hover {
    border-color: var(--accent);
  }

  .popular-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--accent);
    color: var(--dark);
    font-size: 0.75rem;
    font-weight: 700;
    padding: 4px 16px;
    border-radius: 100px;
    letter-spacing: 0.5px;
  }

  .pricing-card__header {
    text-align: center;
    margin-bottom: 28px;
    padding-bottom: 28px;
    border-bottom: 1px solid rgba(230, 233, 255, 0.06);
  }

  .pricing-card__name {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--light);
    margin-bottom: 12px;
  }

  .price-amount {
    font-size: 2.25rem;
    font-weight: 800;
    color: var(--white);
  }

  .price-currency {
    font-size: 0.9rem;
    color: var(--light-400);
    margin-left: 4px;
  }

  .pricing-card__features {
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin-bottom: 32px;
    list-style: none;
    padding: 0;
  }

  .pricing-card__features li {
    font-size: 0.9rem;
    color: var(--light);
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .pricing-card__features li::before {
    font-weight: 700;
    font-size: 1rem;
    flex-shrink: 0;
    width: 18px;
    text-align: center;
  }

  .pricing-card__features li.included::before {
    content: '✓';
    color: #4ade80;
  }

  .pricing-card__features li.excluded {
    color: var(--light-400);
  }

  .pricing-card__features li.excluded::before {
    content: '×';
    color: var(--light-400);
  }

  .feat-val {
    font-weight: 700;
    color: var(--accent);
    min-width: 28px;
  }

  .pricing-note {
    text-align: center;
    margin-top: 40px;
  }

  .pricing-note__link {
    font-size: 0.95rem;
    color: var(--accent);
    font-weight: 600;
    transition: all var(--transition);
  }

  .pricing-note__link:hover {
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  @media (max-width: 900px) {
    .pricing-grid {
      grid-template-columns: 1fr;
      max-width: 400px;
      gap: 20px;
    }

    .pricing-card--popular {
      order: -1;
    }
  }

  @media (max-width: 768px) {
    .pricing-card {
      padding: 32px 24px;
    }

    .pricing-card:hover {
      transform: none;
    }

    .pricing-card__header {
      margin-bottom: 24px;
      padding-bottom: 24px;
    }

    .pricing-card__name {
      font-size: 1.1rem;
    }

    .price-amount {
      font-size: 2rem;
    }

    .pricing-card__features {
      gap: 12px;
      margin-bottom: 28px;
    }

    .pricing-card__features li {
      font-size: 0.85rem;
    }
  }
</style>
