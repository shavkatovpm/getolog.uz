---
import { type Lang, ariza } from "../i18n/translations";

interface Props { lang?: Lang }
const lang = Astro.props.lang || "uz" as Lang;
---

<form class="ariza-form" id="arizaForm" novalidate>
  <div class="ariza-form__row">
    <label class="ariza-form__label" for="ariza-full-name">{ariza.fullName[lang]}</label>
    <input class="ariza-form__input" id="ariza-full-name" name="full_name" type="text" placeholder={ariza.fullNamePlaceholder[lang]} required maxlength="120" />
  </div>

  <div class="ariza-form__row">
    <label class="ariza-form__label" for="ariza-phone">{ariza.phoneNumber[lang]}</label>
    <input class="ariza-form__input" id="ariza-phone" name="phone_number" type="tel" placeholder={ariza.phoneNumberPlaceholder[lang]} required maxlength="20" />
  </div>

  <div class="ariza-form__row">
    <label class="ariza-form__label" for="ariza-telegram">{ariza.telegramUsername[lang]}</label>
    <input class="ariza-form__input" id="ariza-telegram" name="telegram_username" type="text" placeholder={ariza.telegramPlaceholder[lang]} required maxlength="60" />
  </div>

  <div class="ariza-form__row">
    <label class="ariza-form__label" for="ariza-channel">{ariza.channelTopic[lang]}</label>
    <input class="ariza-form__input" id="ariza-channel" name="channel_topic" type="text" placeholder={ariza.channelTopicPlaceholder[lang]} required maxlength="120" />
  </div>

  <div class="ariza-form__row">
    <label class="ariza-form__label" for="ariza-subs">{ariza.subscriberCount[lang]}</label>
    <input class="ariza-form__input" id="ariza-subs" name="subscriber_count" type="text" placeholder={ariza.subscriberPlaceholder[lang]} maxlength="20" />
  </div>

  <div class="ariza-form__row">
    <label class="ariza-form__label" for="ariza-message">{ariza.message[lang]}</label>
    <textarea class="ariza-form__input ariza-form__textarea" id="ariza-message" name="message" placeholder={ariza.messagePlaceholder[lang]} required maxlength="2000" rows="4"></textarea>
  </div>

  <button class="btn btn--primary btn--full ariza-form__submit" type="submit" id="arizaSubmit">
    {ariza.submitBtn[lang]}
  </button>

  <p class="ariza-form__status" id="arizaStatus" role="status" aria-live="polite"></p>
</form>

<script define:vars={{
  submittingText: ariza.submittingBtn[lang],
  submitText: ariza.submitBtn[lang],
  successText: ariza.successMsg[lang],
  errorText: ariza.errorMsg[lang],
  rateLimitText: ariza.rateLimitMsg[lang],
}}>
  function formatFullName(value) {
    return value.replace(/\p{L}+/gu, (word) => word[0].toUpperCase() + word.slice(1).toLowerCase());
  }

  function applyFormatting(input, formatter) {
    input.addEventListener('input', () => {
      const caret = input.selectionStart;
      const before = input.value;
      const after = formatter(before);
      if (after === before) return;
      input.value = after;
      input.setSelectionRange(caret, caret);
    });
  }

  const forms = document.querySelectorAll('#arizaForm');
  forms.forEach((form) => {
    const submitBtn = form.querySelector('#arizaSubmit');
    const statusEl = form.querySelector('#arizaStatus');
    const fullNameInput = form.querySelector('#ariza-full-name');
    const telegramInput = form.querySelector('#ariza-telegram');

    if (fullNameInput) applyFormatting(fullNameInput, formatFullName);

    if (telegramInput) {
      telegramInput.addEventListener('input', () => {
        const value = telegramInput.value;
        if (value.length === 0 || value.startsWith('@')) return;
        const caret = telegramInput.selectionStart ?? value.length;
        telegramInput.value = '@' + value;
        telegramInput.setSelectionRange(caret + 1, caret + 1);
      });
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!(form instanceof HTMLFormElement)) return;
      if (!form.reportValidity()) return;

      const data = Object.fromEntries(new FormData(form).entries());
      submitBtn.disabled = true;
      submitBtn.textContent = submittingText;
      statusEl.textContent = '';
      statusEl.className = 'ariza-form__status';

      try {
        const res = await fetch('https://bot.getolog.uz/api/public/ariza', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });

        if (res.status === 429) {
          statusEl.textContent = rateLimitText;
          statusEl.classList.add('ariza-form__status--error');
        } else if (!res.ok) {
          statusEl.textContent = errorText;
          statusEl.classList.add('ariza-form__status--error');
        } else {
          statusEl.textContent = successText;
          statusEl.classList.add('ariza-form__status--success');
          form.reset();
        }
      } catch {
        statusEl.textContent = errorText;
        statusEl.classList.add('ariza-form__status--error');
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = submitText;
      }
    });
  });
</script>

<style>
  .ariza-form {
    display: flex;
    flex-direction: column;
    gap: 20px;
    max-width: 560px;
    margin: 0 auto;
  }

  .ariza-form__row {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ariza-form__label {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--light);
  }

  .ariza-form__input {
    font-family: 'Inter Tight', sans-serif;
    font-size: 0.95rem;
    padding: 13px 16px;
    border-radius: var(--radius);
    border: 1.5px solid var(--dark-600);
    background: var(--dark-800);
    color: var(--light);
    transition: border-color var(--transition);
  }

  .ariza-form__input::placeholder {
    color: var(--light-400);
  }

  .ariza-form__input:focus {
    outline: none;
    border-color: var(--accent);
  }

  .ariza-form__textarea {
    resize: vertical;
    min-height: 100px;
    font-family: inherit;
  }

  .ariza-form__submit {
    margin-top: 8px;
  }

  .ariza-form__status {
    text-align: center;
    font-size: 0.9rem;
    min-height: 1.2em;
  }

  .ariza-form__status--success {
    color: var(--success);
  }

  .ariza-form__status--error {
    color: var(--danger);
  }
</style>
