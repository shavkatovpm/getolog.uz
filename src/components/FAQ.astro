---
import { type Lang, faq as faqData } from "../i18n/translations";

interface Props { lang?: Lang }
const lang = Astro.props.lang || "uz" as Lang;

const faqs = faqData.items.map(item => ({
  q: item.q[lang],
  a: item.a[lang],
}));
---

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.a
    }
  }))
})} />

<section class="section section--alt" id="faq">
  <div class="container">
    <div class="section__header">
      <h2 class="section__title">{faqData.title[lang]}</h2>
    </div>

    <div class="faq-list" role="list">
      {
        faqs.map((faq, index) => (
          <div class="faq-item" role="listitem">
            <button
              class="faq-item__question"
              aria-expanded="false"
              aria-controls={`faq-answer-${index}`}
              id={`faq-btn-${index}`}
            >
              <span>{faq.q}</span>
              <svg class="faq-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div
              class="faq-item__answer"
              id={`faq-answer-${index}`}
              role="region"
              aria-labelledby={`faq-btn-${index}`}
            >
              <p>{faq.a}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .faq-list {
    max-width: 720px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .faq-item {
    background: var(--dark-800);
    border: 1px solid rgba(230, 233, 255, 0.06);
    border-radius: var(--radius);
    overflow: hidden;
    transition: border-color var(--transition);
  }

  .faq-item.open {
    border-color: rgba(139, 142, 255, 0.2);
  }

  .faq-item__question {
    width: 100%;
    padding: 20px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    background: none;
    border: none;
    color: var(--light);
    font-size: 1.05rem;
    font-weight: 600;
    cursor: pointer;
    text-align: left;
    line-height: 1.4;
  }

  .faq-chevron {
    min-width: 20px;
    transition: transform var(--transition);
    color: var(--light-400);
  }

  .faq-item.open .faq-chevron {
    transform: rotate(180deg);
    color: var(--accent);
  }

  .faq-item__answer {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.4s ease;
  }

  .faq-item.open .faq-item__answer {
    grid-template-rows: 1fr;
  }

  .faq-item__answer > p {
    overflow: hidden;
    padding: 0 24px;
    font-size: 0.95rem;
    color: var(--light-400);
    line-height: 1.7;
    transition: padding 0.3s ease;
  }

  .faq-item.open .faq-item__answer > p {
    padding: 0 24px 20px;
  }

  @media (max-width: 768px) {
    .faq-list {
      gap: 10px;
    }

    .faq-item__question {
      padding: 16px 18px;
      font-size: 0.95rem;
      gap: 12px;
    }

    .faq-item__answer > p {
      padding: 0 18px;
      font-size: 0.9rem;
    }

    .faq-item.open .faq-item__answer > p {
      padding: 0 18px 16px;
    }
  }
</style>

<script>
  const faqItems = document.querySelectorAll(".faq-item");
  const faqButtons = document.querySelectorAll(".faq-item__question");

  faqItems.forEach((item, index) => {
    const btn = item.querySelector(".faq-item__question")!;

    btn.addEventListener("click", () => {
      const isOpen = item.classList.contains("open");

      faqItems.forEach((el) => {
        el.classList.remove("open");
        el.querySelector(".faq-item__question")?.setAttribute("aria-expanded", "false");
      });

      if (!isOpen) {
        item.classList.add("open");
        btn.setAttribute("aria-expanded", "true");
      }
    });

    btn.addEventListener("keydown", (e: KeyboardEvent) => {
      let target: Element | null = null;
      if (e.key === "ArrowDown") {
        e.preventDefault();
        target = faqButtons[(index + 1) % faqButtons.length];
      } else if (e.key === "ArrowUp") {
        e.preventDefault();
        target = faqButtons[(index - 1 + faqButtons.length) % faqButtons.length];
      }
      if (target) (target as HTMLElement).focus();
    });
  });
</script>
