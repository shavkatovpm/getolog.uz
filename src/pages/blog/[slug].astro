---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import { type Lang, langPrefix } from "../../i18n/translations";
import { articles } from "../../data/articles";

interface Props { lang?: Lang }
const lang = Astro.props.lang || "uz" as Lang;
const prefix = langPrefix(lang);

const { slug } = Astro.params;
const article = articles.find((a) => a.slug === slug);

if (!article) {
  return Astro.redirect(prefix + "/blog");
}

const dateObj = new Date(article.date);
const dateStr = dateObj.toLocaleDateString(lang === "uz" ? "uz-UZ" : "ru-RU", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const backText = { uz: "Barcha maqolalar", ru: "Все статьи" };
const readTimeLabel = { uz: "O'qish vaqti", ru: "Время чтения" };
const faqTitle = { uz: "Ko'p so'raladigan savollar", ru: "Часто задаваемые вопросы" };

const articleUrl = `https://getolog.uz${prefix}/blog/${slug}`;
const blogUrl = `https://getolog.uz${prefix}/blog`;
const homeUrl = lang === "uz" ? "https://getolog.uz" : "https://getolog.uz/ru";
const blogLabel = { uz: "Maqolalar", ru: "Статьи" };

const schemaData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": article.title[lang],
      "description": article.description[lang],
      "datePublished": article.date,
      "dateModified": article.date,
      "author": { "@type": "Organization", "name": "Getolog", "url": "https://getolog.uz" },
      "publisher": { "@type": "Organization", "name": "Getolog", "url": "https://getolog.uz", "logo": { "@type": "ImageObject", "url": "https://getolog.uz/logo.png" } },
      "mainEntityOfPage": { "@type": "WebPage", "@id": articleUrl },
      "inLanguage": lang,
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Getolog", "item": homeUrl },
        { "@type": "ListItem", "position": 2, "name": blogLabel[lang], "item": blogUrl },
        { "@type": "ListItem", "position": 3, "name": article.title[lang], "item": articleUrl },
      ],
    },
    ...(article.faq.length > 0 ? [{
      "@type": "FAQPage",
      "mainEntity": article.faq.map((f) => ({
        "@type": "Question",
        "name": f.q[lang],
        "acceptedAnswer": { "@type": "Answer", "text": f.a[lang] },
      })),
    }] : []),
  ],
};

export function getStaticPaths() {
  return articles.map((a) => ({ params: { slug: a.slug } }));
}
---

<Layout title={`${article.title[lang]} — Getolog`} description={article.description[lang]} lang={lang}>
  <Navbar lang={lang} />

  <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />

  <article class="article-page">
    <div class="container">
      <nav class="article-breadcrumb" aria-label="Breadcrumb">
        <a href={homeUrl}>Getolog</a>
        <span>/</span>
        <a href={`${prefix}/blog`}>{blogLabel[lang]}</a>
        <span>/</span>
        <span class="current">{article.title[lang]}</span>
      </nav>

      <header class="article-header">
        <div class="article-meta">
          <span class="article-category">{article.category[lang]}</span>
          <span class="article-date">{dateStr}</span>
          <span class="article-read">{readTimeLabel[lang]}: {article.readTime[lang]}</span>
        </div>
        <h1 class="article-title">{article.title[lang]}</h1>
        <p class="article-desc">{article.description[lang]}</p>
      </header>

      <div class="article-body" set:html={article.html[lang]} />

      {article.faq.length > 0 && (
        <section class="article-faq">
          <h2>{faqTitle[lang]}</h2>
          <div class="faq-list">
            {article.faq.map((f) => (
              <details class="faq-item">
                <summary class="faq-question">{f.q[lang]}</summary>
                <p class="faq-answer">{f.a[lang]}</p>
              </details>
            ))}
          </div>
        </section>
      )}

      <div class="article-cta">
        <p class="article-cta__text">
          {lang === "uz"
            ? "Telegram kanalingizni avtomatlashtirishga tayyormisiz?"
            : "Готовы автоматизировать свой Telegram-канал?"}
        </p>
        <a href="https://t.me/getolog_bot" target="_blank" rel="noopener noreferrer" class="btn btn--primary btn--lg">
          {lang === "uz" ? "Boshlash" : "Начать"}
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </article>

  <Footer lang={lang} />
</Layout>

<style>
  .article-page {
    padding-top: 120px;
    padding-bottom: 80px;
  }

  .article-breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 32px;
    font-size: 0.85rem;
    flex-wrap: wrap;
  }

  .article-breadcrumb a {
    color: var(--accent);
    font-weight: 500;
    transition: all var(--transition);
  }

  .article-breadcrumb a:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .article-breadcrumb span {
    color: var(--light-400);
    opacity: 0.5;
  }

  .article-breadcrumb .current {
    color: var(--light-400);
    opacity: 0.7;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    max-width: 300px;
  }

  .article-header {
    text-align: center;
    max-width: 720px;
    margin: 0 auto 48px;
    padding-bottom: 40px;
    border-bottom: 1px solid rgba(230, 233, 255, 0.06);
  }

  .article-meta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-bottom: 20px;
    flex-wrap: wrap;
  }

  .article-category {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--accent);
    background: rgba(139, 142, 255, 0.1);
    padding: 4px 12px;
    border-radius: 100px;
  }

  .article-date,
  .article-read {
    font-size: 0.85rem;
    color: var(--light-400);
  }

  .article-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    margin-bottom: 16px;
    letter-spacing: -0.5px;
    line-height: 1.25;
  }

  .article-desc {
    font-size: 1.1rem;
    color: var(--light-400);
    line-height: 1.6;
  }

  .article-body {
    max-width: 720px;
    margin: 0 auto;
  }

  .article-body :global(h2) {
    font-size: 1.4rem;
    font-weight: 700;
    margin-top: 40px;
    margin-bottom: 16px;
    color: var(--white);
  }

  .article-body :global(h3) {
    font-size: 1.1rem;
    font-weight: 600;
    margin-top: 28px;
    margin-bottom: 12px;
    color: var(--light);
  }

  .article-body :global(p) {
    font-size: 0.95rem;
    color: var(--light-400);
    line-height: 1.8;
    margin-bottom: 16px;
  }

  .article-body :global(ul),
  .article-body :global(ol) {
    padding-left: 20px;
    margin-bottom: 16px;
  }

  .article-body :global(li) {
    font-size: 0.95rem;
    color: var(--light-400);
    line-height: 1.7;
    margin-bottom: 8px;
  }

  .article-body :global(li strong) {
    color: var(--light);
  }

  .article-body :global(code) {
    background: rgba(139, 142, 255, 0.1);
    padding: 2px 8px;
    border-radius: 4px;
    font-size: 0.9em;
    color: var(--accent);
  }

  .article-cta {
    max-width: 720px;
    margin: 56px auto 0;
    padding-top: 40px;
    border-top: 1px solid rgba(230, 233, 255, 0.06);
    text-align: center;
  }

  .article-cta__text {
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--white);
    margin-bottom: 24px;
  }

  @media (max-width: 768px) {
    .article-page {
      padding-top: 100px;
      padding-bottom: 60px;
    }

    .article-header {
      margin-bottom: 36px;
      padding-bottom: 32px;
    }

    .article-title {
      font-size: 1.5rem;
    }

    .article-desc {
      font-size: 0.95rem;
    }

    .article-body :global(h2) {
      font-size: 1.25rem;
      margin-top: 32px;
    }

    .article-cta {
      margin-top: 40px;
      padding-top: 32px;
    }

    .article-cta__text {
      font-size: 1.05rem;
    }

    .article-faq h2 {
      font-size: 1.25rem;
    }
  }

  /* FAQ */
  .article-faq {
    max-width: 720px;
    margin: 48px auto 0;
    padding-top: 40px;
    border-top: 1px solid rgba(230, 233, 255, 0.06);
  }

  .article-faq h2 {
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--white);
    margin-bottom: 24px;
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .faq-item {
    background: var(--dark-800);
    border: 1px solid rgba(230, 233, 255, 0.06);
    border-radius: var(--radius);
    overflow: hidden;
    transition: border-color var(--transition);
  }

  .faq-item[open] {
    border-color: rgba(139, 142, 255, 0.2);
  }

  .faq-question {
    padding: 18px 24px;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--light);
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .faq-question::-webkit-details-marker {
    display: none;
  }

  .faq-question::after {
    content: '+';
    font-size: 1.3rem;
    font-weight: 400;
    color: var(--accent);
    flex-shrink: 0;
    transition: transform var(--transition);
  }

  .faq-item[open] .faq-question::after {
    content: '\2212';
  }

  .faq-answer {
    padding: 0 24px 18px;
    font-size: 0.9rem;
    color: var(--light-400);
    line-height: 1.7;
    margin: 0;
  }
</style>
