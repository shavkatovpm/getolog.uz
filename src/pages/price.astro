---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import { type Lang, pricing, pricePage as pp, meta, langPrefix } from "../i18n/translations";

interface Props { lang?: Lang }
const lang = Astro.props.lang || "uz" as Lang;
const prefix = langPrefix(lang);

const f = pp.features;
---

<Layout title={meta.priceTitle[lang]} description={meta.priceDesc[lang]} lang={lang}>
  <Navbar lang={lang} />

  <section class="price-hero">
    <div class="container">
      <h1 class="price-hero__title" set:html={pp.heroTitle[lang]} />
      <p class="price-hero__subtitle">{pp.heroSubtitle[lang]}</p>
    </div>
  </section>

  <section class="price-table-section">
    <div class="container">

      <!-- Mobile -->
      <div class="price-cards-mobile">
        <!-- Bepul -->
        <div class="m-card">
          <div class="m-card__head">
            <h3>{pricing.free[lang]}</h3>
            <div class="m-card__price">0 <span>{pricing.currency[lang]}</span></div>
          </div>
          <ul class="m-card__list">
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mSubs[lang]}</span></div><span class="m-value m-highlight">20</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mChannels[lang]}</span></div><span class="m-value">1</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mManage[lang]}</span></div><span class="m-value m-yes">&check;</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mExpiry[lang]}</span></div><span class="m-value m-yes">&check;</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mManualPay[lang]}</span></div><span class="m-value m-yes">&check;</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mPlans[lang]}</span></div><span class="m-value m-yes">&check;</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mPayme[lang]}</span></div><span class="m-value m-no">&times;</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mAnalytics[lang]}</span></div><span class="m-value">{pp.valAsosiy[lang]}</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mReferral[lang]}</span></div><span class="m-value m-no">&times;</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mAutopost[lang]}</span></div><span class="m-value m-no">&times;</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mCleanup[lang]}</span></div><span class="m-value m-no">&times;</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mCRM[lang]}</span></div><span class="m-value m-no">&times;</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mBranding[lang]}</span></div><span class="m-value m-yes">&check;</span></li>
          </ul>
          <a href="https://t.me/getolog_bot" target="_blank" rel="noopener noreferrer" class="btn btn--outline btn--full">{pricing.startBtn[lang]}</a>
        </div>

        <!-- Minimal -->
        <div class="m-card">
          <div class="m-card__head">
            <h3>{pricing.minimal[lang]}</h3>
            <div class="m-card__price">295 000 <span>{pricing.currencyMonth[lang]}</span></div>
          </div>
          <ul class="m-card__list">
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mSubs[lang]}</span></div><span class="m-value m-highlight">100</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mChannels[lang]}</span></div><span class="m-value">1</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mManage[lang]}</span></div><span class="m-value m-yes">&check;</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mExpiry[lang]}</span></div><span class="m-value m-yes">&check;</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mManualPay[lang]}</span></div><span class="m-value m-yes">&check;</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mPlans[lang]}</span></div><span class="m-value m-yes">&check;</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mPayme[lang]}</span></div><span class="m-value m-no">&times;</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mAnalytics[lang]}</span></div><span class="m-value">{pp.valAsosiy[lang]}</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mReferral[lang]}</span></div><span class="m-value m-no">&times;</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mAutopost[lang]}</span></div><span class="m-value m-no">&times;</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mCleanup[lang]}</span></div><span class="m-value m-no">&times;</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mCRM[lang]}</span></div><span class="m-value m-no">&times;</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mBranding[lang]}</span></div><span class="m-value m-no">&times;</span></li>
          </ul>
          <a href="https://t.me/getolog_bot" target="_blank" rel="noopener noreferrer" class="btn btn--outline btn--full">{pricing.startBtn[lang]}</a>
        </div>

        <!-- Standart -->
        <div class="m-card m-card--popular">
          <span class="m-badge">{pricing.badge[lang]}</span>
          <div class="m-card__head">
            <h3>{pricing.start[lang]}</h3>
            <div class="m-card__price">590 000 <span>{pricing.currencyMonth[lang]}</span></div>
          </div>
          <ul class="m-card__list">
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mSubs[lang]}</span></div><span class="m-value m-highlight">200</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mChannels[lang]}</span></div><span class="m-value">1</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mManage[lang]}</span></div><span class="m-value m-yes">&check;</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mExpiry[lang]}</span></div><span class="m-value m-yes">&check;</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mManualPay[lang]}</span></div><span class="m-value m-yes">&check;</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mPlans[lang]}</span></div><span class="m-value m-yes">&check;</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mPayme[lang]}</span></div><span class="m-value m-yes">&check;</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mAnalytics[lang]}</span></div><span class="m-value">{pp.valAsosiy[lang]}</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mReferral[lang]}</span></div><span class="m-value m-no">&times;</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mAutopost[lang]}</span></div><span class="m-value m-no">&times;</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mCleanup[lang]}</span></div><span class="m-value m-no">&times;</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mCRM[lang]}</span></div><span class="m-value m-no">&times;</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mBranding[lang]}</span></div><span class="m-value m-no">&times;</span></li>
          </ul>
          <a href="https://t.me/getolog_bot" target="_blank" rel="noopener noreferrer" class="btn btn--primary btn--full">{pricing.startBtn[lang]}</a>
        </div>

        <!-- Pro -->
        <div class="m-card">
          <div class="m-card__head">
            <h3>{pricing.pro[lang]}</h3>
            <div class="m-card__price">1 270 000 <span>{pricing.currencyMonth[lang]}</span></div>
          </div>
          <ul class="m-card__list">
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mSubs[lang]}</span></div><span class="m-value m-highlight">500</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mChannels[lang]}</span></div><span class="m-value m-highlight">2</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mManage[lang]}</span></div><span class="m-value m-yes">&check;</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mExpiry[lang]}</span></div><span class="m-value m-yes">&check;</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mManualPay[lang]}</span></div><span class="m-value m-yes">&check;</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mPlans[lang]}</span></div><span class="m-value m-yes">&check;</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mPayme[lang]}</span></div><span class="m-value m-yes">&check;</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mAnalytics[lang]}</span></div><span class="m-value m-highlight">{pp.valToliq[lang]}</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mReferral[lang]}</span></div><span class="m-value m-yes">&check;</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mAutopost[lang]}</span></div><span class="m-value m-yes">&check;</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mCleanup[lang]}</span></div><span class="m-value m-yes">&check;</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mCRM[lang]}</span></div><span class="m-value m-no">&times;</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mBranding[lang]}</span></div><span class="m-value m-no">&times;</span></li>
          </ul>
          <a href="https://t.me/getolog_bot" target="_blank" rel="noopener noreferrer" class="btn btn--outline btn--full">{pricing.startBtn[lang]}</a>
        </div>

        <!-- Biznes -->
        <div class="m-card">
          <div class="m-card__head">
            <h3>{pricing.business[lang]}</h3>
            <div class="m-card__price">1 890 000 <span>{pricing.currencyMonth[lang]}</span></div>
          </div>
          <ul class="m-card__list">
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mSubs[lang]}</span></div><span class="m-value m-highlight">1000</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mChannels[lang]}</span></div><span class="m-value m-highlight">3</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mManage[lang]}</span></div><span class="m-value m-yes">&check;</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mExpiry[lang]}</span></div><span class="m-value m-yes">&check;</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mManualPay[lang]}</span></div><span class="m-value m-yes">&check;</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mPlans[lang]}</span></div><span class="m-value m-yes">&check;</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mPayme[lang]}</span></div><span class="m-value m-yes">&check;</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mAnalytics[lang]}</span></div><span class="m-value m-highlight">{pp.valToliqExport[lang]}</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mReferral[lang]}</span></div><span class="m-value m-yes">&check;</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mAutopost[lang]}</span></div><span class="m-value m-yes">&check;</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mCleanup[lang]}</span></div><span class="m-value m-yes">&check;</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mCRM[lang]}</span></div><span class="m-value m-yes">&check;</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mBranding[lang]}</span></div><span class="m-value m-no">&times;</span></li>
          </ul>
          <a href="https://t.me/getolog_bot" target="_blank" rel="noopener noreferrer" class="btn btn--outline btn--full">{pricing.startBtn[lang]}</a>
        </div>
      </div>

      <!-- Desktop table -->
      <div class="price-table-wrap">
        <table class="price-table">
          <thead>
            <tr>
              <th class="feat-col">{pp.featureCol[lang]}</th>
              <th>
                <div class="plan-head">
                  <span class="plan-name">{pricing.free[lang]}</span>
                  <span class="plan-price">0 {pricing.currency[lang]}</span>
                </div>
              </th>
              <th>
                <div class="plan-head">
                  <span class="plan-name">{pricing.minimal[lang]}</span>
                  <span class="plan-price">295 000 {pricing.currencyMonth[lang]}</span>
                </div>
              </th>
              <th class="plan-popular">
                <span class="table-badge">{pricing.badge[lang]}</span>
                <div class="plan-head">
                  <span class="plan-name">{pricing.start[lang]}</span>
                  <span class="plan-price">590 000 {pricing.currencyMonth[lang]}</span>
                </div>
              </th>
              <th>
                <div class="plan-head">
                  <span class="plan-name">{pricing.pro[lang]}</span>
                  <span class="plan-price">1 270 000 {pricing.currencyMonth[lang]}</span>
                </div>
              </th>
              <th>
                <div class="plan-head">
                  <span class="plan-name">{pricing.business[lang]}</span>
                  <span class="plan-price">1 890 000 {pricing.currencyMonth[lang]}</span>
                </div>
              </th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td><div class="feat-name">{f.subs.name[lang]}</div><div class="feat-desc">{f.subs.desc[lang]}</div></td>
              <td>20</td>
              <td>100</td>
              <td class="plan-popular">200</td>
              <td>500</td>
              <td>1000</td>
            </tr>
            <tr>
              <td><div class="feat-name">{f.channels.name[lang]}</div><div class="feat-desc">{f.channels.desc[lang]}</div></td>
              <td>1</td>
              <td>1</td>
              <td class="plan-popular">1</td>
              <td>2</td>
              <td>3</td>
            </tr>
            <tr>
              <td><div class="feat-name">{f.manage.name[lang]}</div><div class="feat-desc">{f.manage.desc[lang]}</div></td>
              <td>&check;</td>
              <td>&check;</td>
              <td class="plan-popular">&check;</td>
              <td>&check;</td>
              <td>&check;</td>
            </tr>
            <tr>
              <td><div class="feat-name">{f.expiry.name[lang]}</div><div class="feat-desc">{f.expiry.desc[lang]}</div></td>
              <td>&check;</td>
              <td>&check;</td>
              <td class="plan-popular">&check;</td>
              <td>&check;</td>
              <td>&check;</td>
            </tr>
            <tr>
              <td><div class="feat-name">{f.manualPay.name[lang]}</div><div class="feat-desc">{f.manualPay.desc[lang]}</div></td>
              <td>&check;</td>
              <td>&check;</td>
              <td class="plan-popular">&check;</td>
              <td>&check;</td>
              <td>&check;</td>
            </tr>
            <tr>
              <td><div class="feat-name">{f.plans.name[lang]}</div><div class="feat-desc">{f.plans.desc[lang]}</div></td>
              <td>&check;</td>
              <td>&check;</td>
              <td class="plan-popular">&check;</td>
              <td>&check;</td>
              <td>&check;</td>
            </tr>
            <tr>
              <td><div class="feat-name">{f.payme.name[lang]}</div><div class="feat-desc">{f.payme.desc[lang]}</div></td>
              <td><span class="t-no">&times;</span></td>
              <td><span class="t-no">&times;</span></td>
              <td class="plan-popular">&check;</td>
              <td>&check;</td>
              <td>&check;</td>
            </tr>
            <tr>
              <td><div class="feat-name">{f.analytics.name[lang]}</div><div class="feat-desc">{f.analytics.desc[lang]}</div></td>
              <td>{pp.valAsosiy[lang]}</td>
              <td>{pp.valAsosiy[lang]}</td>
              <td class="plan-popular">{pp.valAsosiy[lang]}</td>
              <td><span class="t-highlight">{pp.valToliq[lang]}</span></td>
              <td><span class="t-highlight">{pp.valToliqExport[lang]}</span></td>
            </tr>
            <tr>
              <td><div class="feat-name">{f.referral.name[lang]}</div><div class="feat-desc">{f.referral.desc[lang]}</div></td>
              <td><span class="t-no">&times;</span></td>
              <td><span class="t-no">&times;</span></td>
              <td class="plan-popular"><span class="t-no">&times;</span></td>
              <td>&check;</td>
              <td>&check;</td>
            </tr>
            <tr>
              <td><div class="feat-name">{f.autopost.name[lang]}</div><div class="feat-desc">{f.autopost.desc[lang]}</div></td>
              <td><span class="t-no">&times;</span></td>
              <td><span class="t-no">&times;</span></td>
              <td class="plan-popular"><span class="t-no">&times;</span></td>
              <td>&check;</td>
              <td>&check;</td>
            </tr>
            <tr>
              <td><div class="feat-name">{f.cleanup.name[lang]}</div><div class="feat-desc">{f.cleanup.desc[lang]}</div></td>
              <td><span class="t-no">&times;</span></td>
              <td><span class="t-no">&times;</span></td>
              <td class="plan-popular"><span class="t-no">&times;</span></td>
              <td>&check;</td>
              <td>&check;</td>
            </tr>
            <tr>
              <td><div class="feat-name">{f.crm.name[lang]}</div><div class="feat-desc">{f.crm.desc[lang]}</div></td>
              <td><span class="t-no">&times;</span></td>
              <td><span class="t-no">&times;</span></td>
              <td class="plan-popular"><span class="t-no">&times;</span></td>
              <td><span class="t-no">&times;</span></td>
              <td><span class="t-highlight">&check;</span></td>
            </tr>
            <tr>
              <td><div class="feat-name">{f.branding.name[lang]}</div><div class="feat-desc">{f.branding.desc[lang]}</div></td>
              <td>&check;</td>
              <td><span class="t-no">&times;</span></td>
              <td class="plan-popular"><span class="t-no">&times;</span></td>
              <td><span class="t-no">&times;</span></td>
              <td><span class="t-no">&times;</span></td>
            </tr>
          </tbody>
        </table>
      </div>

      <p class="price-scale-note">{pp.scaleNote[lang]}</p>
      <p class="price-hero__intro">{pp.priceIntro[lang]}</p>
    </div>
  </section>

  <!-- CTA -->
  <section class="section" id="cta">
    <div class="container" style="text-align: center;">
      <h2 class="section__title">{pp.ctaTitle[lang]}</h2>
      <p class="section__subtitle" style="margin-bottom: 32px;">{pp.ctaSubtitle[lang]}</p>
      <a href="https://t.me/getolog_bot" target="_blank" rel="noopener noreferrer" class="btn btn--primary btn--lg">
        {pricing.startBtn[lang]}
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </section>

  <Footer lang={lang} />
</Layout>

<style>
  /* Hero */
  .price-hero {
    padding: 140px 0 60px;
    text-align: center;
  }

  .price-hero__title {
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 700;
    margin-bottom: 16px;
    letter-spacing: -0.5px;
  }

  .price-hero__title :global(.price-hero__hand) {
    font-family: 'Kalam', cursive;
    font-weight: 400;
    color: var(--accent);
  }

  .price-hero__subtitle {
    font-size: 1.1rem;
    color: var(--light-400);
    max-width: 480px;
    margin: 0 auto;
  }

  .price-hero__intro {
    font-size: 0.95rem;
    color: var(--light-400);
    max-width: 620px;
    margin: 20px auto 0;
    line-height: 1.7;
  }

  /* Mobile cards — hidden on desktop */
  .price-cards-mobile {
    display: none;
  }

  /* Desktop table */
  .price-table-wrap {
    max-width: 1100px;
    margin: 0 auto;
    overflow-x: auto;
  }

  .price-table-section {
    padding-bottom: 60px;
  }

  .price-scale-note {
    max-width: 720px;
    margin: 0 auto;
    text-align: center;
    font-size: 0.85rem;
    color: var(--light-400);
    line-height: 1.6;
    padding-bottom: 20px;
  }

  .price-table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
  }

  .price-table thead th {
    padding: 28px 16px 24px;
    text-align: center;
    vertical-align: bottom;
    border-bottom: 1px solid rgba(26, 29, 34, 0.08);
    position: relative;
  }

  .price-table thead th.feat-col {
    text-align: left;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--light-400);
    text-transform: uppercase;
    letter-spacing: 1px;
    width: 280px;
  }

  .plan-head {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
