---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import { type Lang, pricing, pricePage as pp, meta, langPrefix } from "../i18n/translations";

interface Props { lang?: Lang }
const lang = Astro.props.lang || "uz" as Lang;
const prefix = langPrefix(lang);

const f = pp.features;
---

<Layout title={meta.priceTitle[lang]} description={meta.priceDesc[lang]} lang={lang}>
  <Navbar lang={lang} />

  <section class="price-hero">
    <div class="container">
      <h1 class="price-hero__title">{pp.heroTitle[lang]}</h1>
      <p class="price-hero__subtitle">{pp.heroSubtitle[lang]}</p>
    </div>
  </section>

  <section class="price-table-section">
    <div class="container">

      <!-- Mobile -->
      <div class="price-cards-mobile">
        <!-- Bepul -->
        <div class="m-card">
          <div class="m-card__head">
            <h3>{pricing.free[lang]}</h3>
            <div class="m-card__price">0 <span>{pricing.currency[lang]}</span></div>
          </div>
          <ul class="m-card__list">
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mBotLimit[lang]}</span><span class="m-desc">{pp.mBotLimitDesc[lang]}</span></div><span class="m-value">{pp.val1[lang]}</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mCard[lang]}</span><span class="m-desc">{pp.mCardDesc[lang]}</span></div><span class="m-value m-yes">&check;</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mStats[lang]}</span><span class="m-desc">{pp.mStatsDesc[lang]}</span></div><span class="m-value m-yes">&check;</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mAuto[lang]}</span><span class="m-desc">{pp.mAutoDesc[lang]}</span></div><span class="m-value m-yes">&check;</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mInvite[lang]}</span><span class="m-desc">{pp.mInviteDesc[lang]}</span></div><span class="m-value m-yes">&check;</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mWelcome[lang]}</span><span class="m-desc">{pp.mWelcomeDesc[lang]}</span></div><span class="m-value m-yes">&check;</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mUsers[lang]}</span><span class="m-desc">{pp.mUsersDesc[lang]}</span></div><span class="m-value m-yes">&check;</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mReceipt[lang]}</span><span class="m-desc">{pp.mReceiptDesc[lang]}</span></div><span class="m-value">{pp.valManual[lang]}</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mMultiAdmin[lang]}</span><span class="m-desc">{pp.mMultiAdminDesc[lang]}</span></div><span class="m-value m-no">&times;</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mPayme[lang]}</span><span class="m-desc">{pp.mPaymeDesc[lang]}</span></div><span class="m-value m-no">&times;</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mAds[lang]}</span><span class="m-desc">{pp.mAdsDesc[lang]}</span></div><span class="m-value m-no">{pp.valYes[lang]}</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mBranding[lang]}</span><span class="m-desc">{pp.mBrandingDesc[lang]}</span></div><span class="m-value m-no">{pp.valYes[lang]}</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mPriority[lang]}</span><span class="m-desc">{pp.mPriorityDesc[lang]}</span></div><span class="m-value m-no">&times;</span></li>
          </ul>
          <a href="https://t.me/getolog_bot" target="_blank" rel="noopener noreferrer" class="btn btn--outline btn--full">{pricing.startBtn[lang]}</a>
        </div>

        <!-- Standard -->
        <div class="m-card m-card--popular">
          <span class="m-badge">{pricing.badge[lang]}</span>
          <div class="m-card__head">
            <h3>{pricing.standard[lang]}</h3>
            <div class="m-card__price">97 000 <span>{pricing.currencyMonth[lang]}</span></div>
          </div>
          <ul class="m-card__list">
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mBotLimit[lang]}</span><span class="m-desc">{pp.mBotLimitDesc[lang]}</span></div><span class="m-value m-highlight">{pp.val2[lang]}</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mMultiAdmin[lang]}</span><span class="m-desc">{pp.mMultiAdminDesc[lang]}</span></div><span class="m-value m-highlight">{pp.val2[lang]}</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mAds[lang]}</span><span class="m-desc">{pp.mAdsDesc[lang]}</span></div><span class="m-value m-yes">{pp.valNo[lang]}</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mCard[lang]}</span><span class="m-desc">{pp.mCardDesc[lang]}</span></div><span class="m-value m-yes">&check;</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mStats[lang]}</span><span class="m-desc">{pp.mStatsDesc[lang]}</span></div><span class="m-value m-yes">&check;</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mAuto[lang]}</span><span class="m-desc">{pp.mAutoDesc[lang]}</span></div><span class="m-value m-yes">&check;</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mInvite[lang]}</span><span class="m-desc">{pp.mInviteDesc[lang]}</span></div><span class="m-value m-yes">&check;</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mWelcome[lang]}</span><span class="m-desc">{pp.mWelcomeDesc[lang]}</span></div><span class="m-value m-yes">&check;</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mUsers[lang]}</span><span class="m-desc">{pp.mUsersDesc[lang]}</span></div><span class="m-value m-yes">&check;</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mReceipt[lang]}</span><span class="m-desc">{pp.mReceiptDesc[lang]}</span></div><span class="m-value">{pp.valManual[lang]}</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mPayme[lang]}</span><span class="m-desc">{pp.mPaymeDesc[lang]}</span></div><span class="m-value m-no">&times;</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mBranding[lang]}</span><span class="m-desc">{pp.mBrandingDesc[lang]}</span></div><span class="m-value m-no">{pp.valYes[lang]}</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mPriority[lang]}</span><span class="m-desc">{pp.mPriorityDesc[lang]}</span></div><span class="m-value m-no">&times;</span></li>
          </ul>
          <a href="https://t.me/getolog_bot" target="_blank" rel="noopener noreferrer" class="btn btn--primary btn--full">{pricing.startBtn[lang]}</a>
        </div>

        <!-- Biznes -->
        <div class="m-card">
          <div class="m-card__head">
            <h3>{pricing.premium[lang]}</h3>
            <div class="m-card__price">497 000 <span>{pricing.currencyMonth[lang]}</span></div>
          </div>
          <ul class="m-card__list">
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mBotLimit[lang]}</span><span class="m-desc">{pp.mBotLimitDesc[lang]}</span></div><span class="m-value m-highlight">{pp.val5[lang]}</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mMultiAdmin[lang]}</span><span class="m-desc">{pp.mMultiAdminDesc[lang]}</span></div><span class="m-value m-highlight">{pp.val5[lang]}</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mAds[lang]}</span><span class="m-desc">{pp.mAdsDesc[lang]}</span></div><span class="m-value m-yes">{pp.valNo[lang]}</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mBranding[lang]}</span><span class="m-desc">{pp.mBrandingDesc[lang]}</span></div><span class="m-value m-yes">{pp.valNo[lang]}</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mPayme[lang]}</span><span class="m-desc">{pp.mPaymeDesc[lang]}</span></div><span class="m-value m-yes">&check;</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mCard[lang]}</span><span class="m-desc">{pp.mCardDesc[lang]}</span></div><span class="m-value m-yes">&check;</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mStats[lang]}</span><span class="m-desc">{pp.mStatsDesc[lang]}</span></div><span class="m-value m-yes">&check;</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mAuto[lang]}</span><span class="m-desc">{pp.mAutoDesc[lang]}</span></div><span class="m-value m-yes">&check;</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mInvite[lang]}</span><span class="m-desc">{pp.mInviteDesc[lang]}</span></div><span class="m-value m-yes">&check;</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mWelcome[lang]}</span><span class="m-desc">{pp.mWelcomeDesc[lang]}</span></div><span class="m-value m-yes">&check;</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mUsers[lang]}</span><span class="m-desc">{pp.mUsersDesc[lang]}</span></div><span class="m-value m-yes">&check;</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mReceipt[lang]}</span><span class="m-desc">{pp.mReceiptDesc[lang]}</span></div><span class="m-value m-highlight">{pp.valAuto[lang]}</span></li>
            <li class="m-feat"><div class="m-label-wrap"><span class="m-label">{pp.mPriority[lang]}</span><span class="m-desc">{pp.mPriorityDesc[lang]}</span></div><span class="m-value m-yes">&check;</span></li>
          </ul>
          <a href="https://t.me/getolog_bot" target="_blank" rel="noopener noreferrer" class="btn btn--outline btn--full">{pricing.startBtn[lang]}</a>
        </div>
      </div>

      <!-- Desktop table -->
      <div class="price-table-wrap">
        <table class="price-table">
          <thead>
            <tr>
              <th class="feat-col">{pp.featureCol[lang]}</th>
              <th>
                <div class="plan-head">
                  <span class="plan-name">{pricing.free[lang]}</span>
                  <span class="plan-price">0 {pricing.currency[lang]}</span>
                </div>
              </th>
              <th class="plan-popular">
                <span class="table-badge">{pricing.badge[lang]}</span>
                <div class="plan-head">
                  <span class="plan-name">{pricing.standard[lang]}</span>
                  <span class="plan-price">97 000 {pricing.currencyMonth[lang]}</span>
                </div>
              </th>
              <th>
                <div class="plan-head">
                  <span class="plan-name">{pricing.premium[lang]}</span>
                  <span class="plan-price">497 000 {pricing.currencyMonth[lang]}</span>
                </div>
              </th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td><div class="feat-name">{f.card.name[lang]}</div><div class="feat-desc">{f.card.desc[lang]}</div></td>
              <td>&check;</td>
              <td class="plan-popular">&check;</td>
              <td>&check;</td>
            </tr>
            <tr>
              <td><div class="feat-name">{f.stats.name[lang]}</div><div class="feat-desc">{f.stats.desc[lang]}</div></td>
              <td>&check;</td>
              <td class="plan-popular">&check;</td>
              <td>&check;</td>
            </tr>
            <tr>
              <td><div class="feat-name">{f.auto.name[lang]}</div><div class="feat-desc">{f.auto.desc[lang]}</div></td>
              <td>&check;</td>
              <td class="plan-popular">&check;</td>
              <td>&check;</td>
            </tr>
            <tr>
              <td><div class="feat-name">{f.invite.name[lang]}</div><div class="feat-desc">{f.invite.desc[lang]}</div></td>
              <td>&check;</td>
              <td class="plan-popular">&check;</td>
              <td>&check;</td>
            </tr>
            <tr>
              <td><div class="feat-name">{f.welcome.name[lang]}</div><div class="feat-desc">{f.welcome.desc[lang]}</div></td>
              <td>&check;</td>
              <td class="plan-popular">&check;</td>
              <td>&check;</td>
            </tr>
            <tr>
              <td><div class="feat-name">{f.users.name[lang]}</div><div class="feat-desc">{f.users.desc[lang]}</div></td>
              <td>&check;</td>
              <td class="plan-popular">&check;</td>
              <td>&check;</td>
            </tr>
            <tr>
              <td><div class="feat-name">{f.botLimit.name[lang]}</div><div class="feat-desc">{f.botLimit.desc[lang]}</div></td>
              <td>{pp.val1[lang]}</td>
              <td class="plan-popular">{pp.val2[lang]}</td>
              <td>{pp.val5[lang]}</td>
            </tr>
            <tr>
              <td><div class="feat-name">{f.multiAdmin.name[lang]}</div><div class="feat-desc">{f.multiAdmin.desc[lang]}</div></td>
              <td><span class="t-no">&times;</span></td>
              <td class="plan-popular">{pp.val2[lang]}</td>
              <td>{pp.val5[lang]}</td>
            </tr>
            <tr>
              <td><div class="feat-name">{f.ads.name[lang]}</div><div class="feat-desc">{f.ads.desc[lang]}</div></td>
              <td><span class="t-no">{pp.valYes[lang]}</span></td>
              <td class="plan-popular"><span class="t-yes">{pp.valNo[lang]}</span></td>
              <td><span class="t-yes">{pp.valNo[lang]}</span></td>
            </tr>
            <tr>
              <td><div class="feat-name">{f.branding.name[lang]}</div><div class="feat-desc">{f.branding.desc[lang]}</div></td>
              <td><span class="t-no">{pp.valYes[lang]}</span></td>
              <td class="plan-popular"><span class="t-no">{pp.valYes[lang]}</span></td>
              <td><span class="t-yes">{pp.valNo[lang]}</span></td>
            </tr>
            <tr>
              <td><div class="feat-name">{f.receipt.name[lang]}</div><div class="feat-desc">{f.receipt.desc[lang]}</div></td>
              <td>{pp.valManual[lang]}</td>
              <td class="plan-popular">{pp.valManual[lang]}</td>
              <td><span class="t-highlight">{pp.valAuto[lang]}</span></td>
            </tr>
            <tr>
              <td><div class="feat-name">{f.payme.name[lang]}</div><div class="feat-desc">{f.payme.desc[lang]}</div></td>
              <td><span class="t-no">&times;</span></td>
              <td class="plan-popular"><span class="t-no">&times;</span></td>
              <td>&check;</td>
            </tr>
            <tr>
              <td><div class="feat-name">{f.priority.name[lang]}</div><div class="feat-desc">{f.priority.desc[lang]}</div></td>
              <td><span class="t-no">&times;</span></td>
              <td class="plan-popular"><span class="t-no">&times;</span></td>
              <td>&check;</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section" id="cta">
    <div class="container" style="text-align: center;">
      <h2 class="section__title">{pp.ctaTitle[lang]}</h2>
      <p class="section__subtitle" style="margin-bottom: 32px;">{pp.ctaSubtitle[lang]}</p>
      <a href="https://t.me/getolog_bot" target="_blank" rel="noopener noreferrer" class="btn btn--primary btn--lg">
        {pricing.startBtn[lang]}
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </section>

  <Footer lang={lang} />
</Layout>

<style>
  /* Hero */
  .price-hero {
    padding: 140px 0 60px;
    text-align: center;
  }

  .price-hero__title {
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 700;
    margin-bottom: 16px;
    letter-spacing: -0.5px;
  }

  .price-hero__subtitle {
    font-size: 1.1rem;
    color: var(--light-400);
    max-width: 480px;
    margin: 0 auto;
  }

  /* Mobile cards — hidden on desktop */
  .price-cards-mobile {
    display: none;
  }

  /* Desktop table */
  .price-table-wrap {
    max-width: 960px;
    margin: 0 auto;
  }

  .price-table-section {
    padding-bottom: 80px;
  }

  .price-table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
  }

  .price-table thead th {
    padding: 28px 16px 24px;
    text-align: center;
    vertical-align: bottom;
    border-bottom: 1px solid rgba(230, 233, 255, 0.08);
    position: relative;
  }

  .price-table thead th.feat-col {
    text-align: left;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--light-400);
    text-transform: uppercase;
    letter-spacing: 1px;
    width: 280px;
  }

  .plan-head {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }

  .plan-name {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--white);
  }

  .plan-price {
    font-size: 0.85rem;
    color: var(--light-400);
    font-weight: 400;
  }

  .plan-popular {
    background: rgba(139, 142, 255, 0.04);
  }

  .table-badge {
    display: inline-block;
    background: var(--accent);
    color: var(--dark);
    font-size: 0.65rem;
    font-weight: 700;
    padding: 2px 10px;
    border-radius: 100px;
    margin-bottom: 8px;
    letter-spacing: 0.5px;
  }

  .price-table tbody td {
    padding: 14px 16px;
    text-align: center;
    font-size: 0.9rem;
    border-bottom: 1px solid rgba(230, 233, 255, 0.04);
    color: var(--light);
  }

  .price-table tbody td:first-child {
    text-align: left;
    color: var(--light-200);
    font-weight: 500;
  }

  .feat-name {
    font-weight: 500;
    color: var(--light-200);
  }

  .feat-desc {
    font-size: 0.78rem;
    color: var(--light-400);
    font-weight: 400;
    margin-top: 2px;
    opacity: 0.7;
  }

  .price-table tbody tr:hover td {
    background: rgba(230, 233, 255, 0.02);
  }

  .price-table tfoot td {
    padding: 24px 16px 0;
  }

  .t-no {
    color: var(--light-400);
    opacity: 0.5;
  }

  .t-yes {
    color: var(--success);
  }

  .t-highlight {
    color: var(--accent);
    font-weight: 600;
  }

  /* Mobile card styles */
  .m-card {
    background: var(--dark-800);
    border: 1px solid rgba(230, 233, 255, 0.06);
    border-radius: var(--radius-lg);
    padding: 28px 24px;
    margin-bottom: 16px;
    position: relative;
  }

  .m-card--popular {
    border-color: var(--accent);
  }

  .m-badge {
    position: absolute;
    top: -10px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--accent);
    color: var(--dark);
    font-size: 0.7rem;
    font-weight: 700;
    padding: 3px 14px;
    border-radius: 100px;
  }

  .m-card__head {
    text-align: center;
    margin-bottom: 20px;
    padding-bottom: 16px;
    border-bottom: 1px solid rgba(230, 233, 255, 0.06);
  }

  .m-card__head h3 {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--white);
    margin-bottom: 6px;
  }

  .m-card__price {
    font-size: 1.75rem;
    font-weight: 800;
    color: var(--white);
  }

  .m-card__price span {
    font-size: 0.8rem;
    color: var(--light-400);
    font-weight: 400;
  }

  .m-card__list {
    list-style: none;
    padding: 0;
    margin-bottom: 24px;
  }

  .m-feat {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 0;
    border-bottom: 1px solid rgba(230, 233, 255, 0.03);
    font-size: 0.85rem;
  }

  .m-label-wrap {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .m-label {
    color: var(--light-200);
  }

  .m-desc {
    font-size: 0.75rem;
    color: var(--light-400);
    font-weight: 400;
    opacity: 0.7;
  }

  .m-value {
    font-weight: 600;
    color: var(--light);
  }

  .m-value.m-yes {
    color: var(--success);
    font-weight: 700;
  }

  .m-value.m-no {
    color: var(--light-400);
    opacity: 0.5;
    font-weight: 400;
  }

  .m-value.m-highlight {
    color: var(--accent);
    font-weight: 700;
  }

  @media (max-width: 768px) {
    .price-table-wrap {
      display: none;
    }

    .price-cards-mobile {
      display: flex;
      flex-direction: column;
      max-width: 420px;
      margin: 0 auto;
    }

    .price-hero {
      padding: 110px 0 40px;
    }

    .price-hero__title {
      font-size: 1.75rem;
    }

    .price-hero__subtitle {
      font-size: 0.95rem;
    }

    .price-table-section {
      padding-bottom: 40px;
    }
  }
</style>
