---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="404 — Sahifa topilmadi | Getolog" description="Kechirasiz, siz qidirayotgan sahifa topilmadi.">
  <Navbar />

  <section class="error-page">
    <div class="container error-page__inner">
      <span class="error-page__code">404</span>
      <h1 class="error-page__title">Sahifa topilmadi</h1>
      <p class="error-page__desc">Kechirasiz, siz qidirayotgan sahifa mavjud emas yoki ko'chirilgan.</p>
      <a href="/" class="btn btn--primary btn--lg">Bosh sahifaga qaytish</a>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .error-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 120px 0 80px;
  }

  .error-page__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }

  .error-page__code {
    font-size: clamp(6rem, 15vw, 10rem);
    font-weight: 800;
    color: var(--accent);
    line-height: 1;
    opacity: 0.15;
  }

  .error-page__title {
    font-size: clamp(1.5rem, 4vw, 2.25rem);
    font-weight: 700;
    margin-top: -20px;
  }

  .error-page__desc {
    font-size: 1.05rem;
    color: var(--light-400);
    max-width: 400px;
    line-height: 1.6;
    margin-bottom: 16px;
  }
</style>
