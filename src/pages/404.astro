---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import { notFound } from "../i18n/translations";
---

<Layout title={notFound.title.uz} description={notFound.desc.uz}>
  <Navbar />

  <section class="error-page">
    <div class="container error-page__inner">
      <span class="error-page__code">404</span>
      <h1 class="error-page__title" data-uz={notFound.heading.uz} data-ru={notFound.heading.ru}>{notFound.heading.uz}</h1>
      <p class="error-page__desc" data-uz={notFound.text.uz} data-ru={notFound.text.ru}>{notFound.text.uz}</p>
      <a href="/" class="btn btn--primary btn--lg error-page__btn" data-uz={notFound.btn.uz} data-ru={notFound.btn.ru}>{notFound.btn.uz}</a>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .error-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 120px 0 80px;
  }

  .error-page__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }

  .error-page__code {
    font-size: clamp(6rem, 15vw, 10rem);
    font-weight: 800;
    color: var(--accent);
    line-height: 1;
    opacity: 0.15;
  }

  .error-page__title {
    font-size: clamp(1.5rem, 4vw, 2.25rem);
    font-weight: 700;
    margin-top: -20px;
  }

  .error-page__desc {
    font-size: 1.05rem;
    color: var(--light-400);
    max-width: 400px;
    line-height: 1.6;
    margin-bottom: 16px;
  }
</style>

<script>
  if (window.location.pathname.startsWith("/ru")) {
    document.documentElement.lang = "ru";
    document.querySelectorAll("[data-ru]").forEach((el) => {
      const ru = el.getAttribute("data-ru")!;
      if (el.tagName === "A") {
        el.textContent = ru;
        (el as HTMLAnchorElement).href = "/ru/";
      } else {
        el.textContent = ru;
      }
    });
  }
</script>
