# Getolog Bot Configuration

# Main Getolog bot token (from @BotFather)
BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# PostgreSQL (Neon free tier)
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.us-east-2.aws.neon.tech/getolog

# Redis (local)
REDIS_URL=redis://localhost:6379/0

# Fernet encryption key for bot tokens (generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=your-fernet-key-here

# Moderator Telegram IDs (comma-separated)
MODERATOR_IDS=123456789

# Server URL (for webhook registration)
SERVER_URL=https://getolog.uz

# Webhook server port
WEBHOOK_PORT=8443

# Sentry DSN (optional, for error tracking)
SENTRY_DSN=

# Environment
ENV=production
