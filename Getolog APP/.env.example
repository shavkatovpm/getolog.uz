# Postgres ulanish manzili
DATABASE_URL=postgresql+asyncpg://getolog:getolog@localhost:5432/getolog

# Bot tokenlarini bazada shifrlab saqlash uchun kalit.
# Yaratish: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# GETOLOG bosh botining BotFather'dan olingan tokeni
MAIN_BOT_TOKEN=

# GETOLOG egasining Telegram ID raqami — faqat shu ID owner panelga kira oladi
OWNER_TELEGRAM_ID=

# Webhooklar uchun ochiq HTTPS domen (masalan https://getolog.uz), oxirida / bo'lmasin
WEBHOOK_BASE_URL=

# Mahalliy webhook serveri qaysi portda tinglaydi
WEBHOOK_SERVER_PORT=8080

# Dashboard (Next.js) uchun JWT imzolash kaliti.
# Yaratish: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=

# Dashboard qaysi domendan so'rov yuborishi mumkin (CORS)
DASHBOARD_ORIGIN=https://app.getolog.uz
